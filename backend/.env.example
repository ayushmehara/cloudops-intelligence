# ============ APP CONFIGURATION ============
APP_NAME=CloudOps Intelligence
APP_VERSION=1.0.0
DEBUG=False

# ============ DATABASE ============
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://cloudops:cloudops123@postgres:5432/cloudops_db
SQLALCHEMY_ECHO=False

# ============ SERVER ============
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============ SECURITY ============
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production-with-32-bytes
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============ AI/LLM ============
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
AI_ENABLED=True

# ============ MONITORING ============
PROMETHEUS_ENABLED=True
METRICS_PORT=9090

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============ EXTERNAL SERVICES ============
# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty API key for incident escalation
PAGERDUTY_API_KEY=your-pagerduty-api-key
